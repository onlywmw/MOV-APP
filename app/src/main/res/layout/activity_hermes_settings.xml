<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="返回"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_chip"
                android:minWidth="72dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="⚙️ AI 设置"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSettingsStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="状态"
            android:textColor="@color/accent_light"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="服务商"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/spinnerProvider"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="API 地址（可留空用默认）"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etBaseUrl"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input"
            android:hint="https://api.deepseek.com/v1"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="textUri"
            android:singleLine="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="API Key"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etApiKey"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:hint="填写 API Key"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="textPassword"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnClearKey"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:text="✕"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:background="@drawable/bg_chip" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="模型（可留空用默认）"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etModel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input"
            android:hint="deepseek-chat"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="text"
            android:singleLine="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="系统提示词"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etSystemPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input"
            android:hint="你是 Hermes…"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:padding="12dp"
            android:minLines="3"
            android:gravity="top"
            android:inputType="textMultiLine" />

        <Switch
            android:id="@+id/switchEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="启用 AI 回答（关闭则只用本地指令）"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="界面语言"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/spinnerLanguage"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="保存"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_send" />

            <Button
                android:id="@+id/btnTest"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="测试连接"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_send" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
